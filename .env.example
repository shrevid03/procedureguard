# This file documents what the scripts read. Do NOT commit the real .env.
# Generated values come from scripts/00_provision_azure.sh

AZ_RESOURCE_GROUP=rg-procedureguard
AZ_LOCATION=centralindia

# Layer 1 / 4 - Blob Storage
STORAGE_ACCOUNT=
STORAGE_CONTAINER=sop-docs
STORAGE_KEY=
STORAGE_CONNECTION_STRING=

# Layer 2 - Azure AI Search (Basic tier)
SEARCH_ENDPOINT=
SEARCH_ADMIN_KEY=
SEARCH_INDEX_NAME=procedureguard-sop-text
SEARCH_API_VERSION=2024-07-01

# GitHub Models - free GPT-4o + text-embedding-3-large
# Generate token at https://github.com/settings/tokens (no scopes required)
# Rate limits: 50 requests/day, 10 requests/minute (resets at midnight UTC)
GITHUB_TOKEN=
GPT4O_BASE_URL=https://models.inference.ai.azure.com

# Azure OpenAI (BLOCKED on Azure for Students subscriptions - replaced by GitHub Models)
# AOAI_ENDPOINT=
# AOAI_KEY=
# AOAI_GPT4O_DEPLOYMENT=gpt-4o
# AOAI_EMBED_DEPLOYMENT=text-embedding-3-large

# Multi-service Cognitive (for Document Intelligence + Vision - optional path)
# COG_ENDPOINT=
# COG_KEY=
